{
  "expo": {
    "name": "@ccore/mobile",
    "slug": "ccore-mobile",
    "version": "1.0.0",
    "scheme": "ccore",
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTabletMode": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-document-picker",
        {
          "iCloudContainerEnvironment": "Production"
        }
      ],
      [
        "expo-file-system",
        {
          "fileSystem": {
            "directory": "documentDirectory"
          }
        }
      ]
    ]
  }
}
