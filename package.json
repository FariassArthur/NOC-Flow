{
  "name": "@noc/root",
  "private": true,
  "version": "1.0.0",
  "description": "NOC - Network Occurrence Management System",
  "scripts": {
    "install-all": "pnpm install",
    "dev": "pnpm -r --parallel run dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "type-check": "pnpm -r type-check",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,json,md}\""
  },
  "keywords": [
    "network",
    "occurrence",
    "management",
    "noc",
    "typescript",
    "monorepo"
  ],
  "author": "Network Analysis Team",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.10.0",
    "prettier": "^3.1.0",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  }
}
